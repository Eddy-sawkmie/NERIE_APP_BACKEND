	<subDataset name="Participant Dataset" uuid="3c2cf58d-cdcb-4c03-8822-bd2c87805872">
		<parameter name="pphaseid" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT UL.username,UL.userid,UL.usermobile,P.gender,CT.categoryname,D.designationname,PO.participantofficetypename,S.statename,
P.participantofficeaddress,P.participantteachingsubjects,A.applicationcode
FROM nerie.mt_userlogin UL
INNER JOIN nerie.t_participants P ON P.usercode=UL.usercode
INNER JOIN nerie.t_applications A ON P.usercode=A.usercode
LEFT OUTER JOIN nerie.m_designations D ON P.participantdesignationcode=D.designationcode
LEFT OUTER JOIN nerie.m_categories CT ON CT.categorycode=P.categorycode
LEFT OUTER JOIN nerie.m_participantofficetypes PO ON PO.participantofficetypecode=P.participantofficetypecode
LEFT OUTER JOIN nerie.m_states S ON S.statecode=P.participantofficestatecode
WHERE A.phaseid=$P{pphaseid} AND A.status='A'
ORDER BY UL.username]]>
		</queryString>
		<field name="username" class="java.lang.String"/>
		<field name="userid" class="java.lang.String"/>
		<field name="usermobile" class="java.lang.String"/>
		<field name="gender" class="java.lang.String"/>
		<field name="categoryname" class="java.lang.String"/>
		<field name="designationname" class="java.lang.String"/>
		<field name="participantofficetypename" class="java.lang.String"/>
		<field name="statename" class="java.lang.String"/>
		<field name="participantofficeaddress" class="java.lang.String"/>
		<field name="participantteachingsubjects" class="java.lang.String"/>
		<field name="applicationcode" class="java.lang.String"/>
	</subDataset>
	<subDataset name="Table Dataset 1" uuid="80bc901c-6502-4f5a-b55c-1df24c5d51b3"/>
	<subDataset name="Recource Person Dataset" uuid="1f7a061c-bd8f-4da8-8c70-3f2f95aa4088">
		<parameter name="rpphaseid" class="java.lang.String"/>
		<queryString>
			<![CDATA[select a.rpemailid,a.rpname,a.rpinstitutename,a.rpofficeaddress,rpd.qualificationname,a.rpspecialization,
d.designationname,a.rpmobileno,a.rpresidentialaddress,a.rpofficephone,a.rpresidencephone,a.rpfax
from nerie.mt_resourcepersons a
inner join nerie.mt_resourcepersoncoursemap b on a.rpslno=b.rpslno
inner join nerie.m_designations d on a.designationcode=d.designationcode
inner join nerie.m_qualifications rpd on rpd.qualificationcode=a.qualificationcode where b.phaseid=$P{rpphaseid}
order by a.rpname]]>
		</queryString>
		<field name="rpemailid" class="java.lang.String"/>
		<field name="rpname" class="java.lang.String"/>
		<field name="rpinstitutename" class="java.lang.String"/>
		<field name="rpofficeaddress" class="java.lang.String"/>
		<field name="qualificationname" class="java.lang.String"/>
		<field name="rpspecialization" class="java.lang.String"/>
		<field name="designationname" class="java.lang.String"/>
		<field name="rpmobileno" class="java.lang.String"/>
		<field name="rpresidentialaddress" class="java.lang.String"/>
		<field name="rpofficephone" class="java.lang.String"/>
		<field name="rpresidencephone" class="java.lang.String"/>
		<field name="rpfax" class="java.lang.String"/>
	</subDataset>
	<subDataset name="coordinators" uuid="62ead7d2-146a-4998-93e2-19dd9b8012cd">
		<parameter name="cphaseid" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT
    x.usercode,
    x.username,
    x.designationname,
    x.officeshortname
FROM (
    SELECT DISTINCT
        UL.usercode,
        UL.username,
        D.designationname,
        O.officeshortname,
        CC.isheadcoordinator
    FROM nerie.mt_program_members CC
    INNER JOIN nerie.mt_programdetails C ON C.phaseid = CC.phaseid
    INNER JOIN nerie.mt_userlogin UL ON CC.usercode = UL.usercode
    INNER JOIN nerie.m_designations D ON D.designationcode = UL.designationcode
    INNER JOIN nerie.m_offices O ON O.officecode = UL.officecode
    INNER JOIN nerie.m_phases ph ON C.phaseid = ph.phaseid
    WHERE C.phaseid = $P{cphaseid}
) x
ORDER BY
    CASE
        WHEN x.isheadcoordinator = '1' THEN 0
        ELSE 1
    END,
    x.username;
]]>
		</queryString>
		<field name="usercode" class="java.lang.String"/>
		<field name="username" class="java.lang.String"/>
		<field name="designationname" class="java.lang.String"/>
		<field name="officeshortname" class="java.lang.String"/>
		<group name="usercode">
			<groupExpression><![CDATA[$F{usercode}]]></groupExpression>
		</group>
		<group name="username">
			<groupExpression><![CDATA[$F{username}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="phaseid" class="java.lang.String"/>
	<parameter name="dynamicpath" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
    p.programname,
    p.programid,
    p.programcode,
    p.programdescription,
    pd.phaseid,
    ph.phaseno,
    ph.phasedescription,
    pd.startdate,
    pd.enddate,
    o.officename || ',' || o.officeaddress || '-' || o.officepincode AS office,
    pd.enddate - pd.startdate + 1 AS noofdays,

    /* Coordinators: head first, no duplicates */
    (
        SELECT string_agg(
                   c.coordinator_text,
                   '  *  '
                   ORDER BY c.sort_order, c.username
               )
        FROM (
            SELECT DISTINCT
                cc.phaseid,
                u.username,
                u.username || ' Designation: ' || d.designationname || ', Office: ' || o2.officeshortname
                    AS coordinator_text,
                CASE
                    WHEN cc.isheadcoordinator = '1' THEN 0
                    ELSE 1
                END AS sort_order
            FROM nerie.mt_program_members cc
            JOIN nerie.mt_userlogin u ON u.usercode = cc.usercode
            JOIN nerie.m_designations d ON d.designationcode = u.designationcode
            JOIN nerie.m_offices o2 ON u.officecode = o2.officecode
            WHERE cc.phaseid = pd.phaseid
        ) c
    ) AS coordinator,

    /* Venues */
    (
        SELECT string_agg(DISTINCT v.venuename, ',')
        FROM nerie.mt_programvenues vc
        JOIN nerie.m_venues v ON v.venuecode = vc.venuecode
        WHERE vc.phaseid = pd.phaseid
    ) AS venuname

FROM nerie.mt_programdetails pd
JOIN nerie.m_programs p ON p.programcode = pd.programcode
JOIN nerie.m_offices o ON p.officecode = o.officecode
JOIN nerie.m_phases ph ON ph.phaseid = pd.phaseid

WHERE pd.phaseid = $P{phaseid};]]>
	</queryString>
	<field name="programname" class="java.lang.String"/>
	<field name="programid" class="java.lang.String"/>
	<field name="programcode" class="java.lang.String"/>
	<field name="programdescription" class="java.lang.String"/>
	<field name="phaseid" class="java.lang.String"/>
	<field name="phaseno" class="java.lang.String">
		<fieldDescription><![CDATA[This will be the phase number of a program. it will be 1 by default for all programs and will be incremented for each phase of a program by a valur of 1 if that program has multiple phases]]></fieldDescription>
	</field>
	<field name="phasedescription" class="java.lang.String"/>
	<field name="startdate" class="java.sql.Date"/>
	<field name="enddate" class="java.sql.Date"/>
	<field name="office" class="java.lang.String"/>
	<field name="noofdays" class="java.lang.Integer"/>
	<field name="coordinator" class="java.lang.String"/>
	<field name="venuname" class="java.lang.String"/>
