	<subDataset name="participantslist" uuid="6f0e2920-7da2-4a76-a595-a3af0c658fa4">
		<parameter name="pphaseid" class="java.lang.String"/>
		<queryString>
			<![CDATA[select distinct(a.usercode), a.applicationcode, a.phaseid, u.username
FROM nerie.t_applications a, nerie.mt_userlogin u, nerie.mt_programdetails pd
where a.phaseid=$P{pphaseid} and a.status='A' and u.usercode=a.usercode and a.phaseid=pd.phaseid]]>
		</queryString>
		<field name="usercode" class="java.lang.String"/>
		<field name="applicationcode" class="java.lang.String"/>
		<field name="phaseid" class="java.lang.String"/>
		<field name="username" class="java.lang.String"/>
	</subDataset>
	<subDataset name="coordinator" uuid="941adaf0-dd7f-4368-869d-7b8c8463b44e">
		<parameter name="ccphaseid" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT
    x.usercode,
    x.username,
    x.designationname,
    x.officeshortname
FROM (
    SELECT DISTINCT
        UL.usercode,
        UL.username,
        D.designationname,
        O.officeshortname,
        CC.isheadcoordinator
    FROM nerie.mt_program_members CC
    INNER JOIN nerie.mt_programdetails C ON C.phaseid = CC.phaseid
    INNER JOIN nerie.mt_userlogin UL ON CC.usercode = UL.usercode
    INNER JOIN nerie.m_designations D ON D.designationcode = UL.designationcode
    INNER JOIN nerie.m_offices O ON O.officecode = UL.officecode
    INNER JOIN nerie.m_phases ph ON C.phaseid = ph.phaseid
    WHERE C.phaseid = $P{ccphaseid}
) x
ORDER BY
    CASE
        WHEN x.isheadcoordinator = '1' THEN 0
        ELSE 1
    END,
    x.username;]]>
		</queryString>
		<field name="usercode" class="java.lang.String"/>
		<field name="username" class="java.lang.String"/>
		<field name="designationname" class="java.lang.String"/>
		<field name="officeshortname" class="java.lang.String"/>
		<group name="usercode">
			<groupExpression><![CDATA[$F{usercode}]]></groupExpression>
		</group>
		<group name="username">
			<groupExpression><![CDATA[$F{username}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="phaseid" class="java.lang.String"/>
	<parameter name="dynamicpath" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT p.programname, p.programdescription, p.programid, ph.phaseno, ph.phasedescription, pd.startdate, pd.enddate, pd.programcode,


array_to_string
(
ARRAY(
SELECT UL.username || ', Designation: ' || D.designationname || ', Office: ' || O.officeshortname FROM nerie.mt_program_members CC
INNER JOIN nerie.mt_userlogin UL ON CC.usercode=UL.usercode
INNER JOIN nerie.m_designations D ON D.designationcode=UL.designationcode
INNER JOIN nerie.m_offices O ON O.officecode=UL.officecode
INNER JOIN nerie.mt_programdetails pr ON pr.phaseid=CC.phaseid
INNER JOIN nerie.m_phases ph ON pr.phaseid=ph.phaseid
WHERE pd.phaseid=CC.phaseid ORDER BY UL.usercode
), '  *  '
) AS coursecoordinator

FROM nerie.m_programs p, nerie.m_phases ph, nerie.mt_programdetails pd
WHERE p.programcode=ph.programcode AND p.programcode=pd.programcode AND ph.phaseid=$P{phaseid}]]>
	</queryString>
	<field name="programname" class="java.lang.String"/>
	<field name="programdescription" class="java.lang.String"/>
	<field name="programid" class="java.lang.String"/>
	<field name="phaseno" class="java.lang.String"/>
	<field name="phasedescription" class="java.lang.String"/>
	<field name="startdate" class="java.sql.Date"/>
	<field name="enddate" class="java.sql.Date"/>
	<field name="programcode" class="java.lang.String"/>
	<field name="coursecoordinator" class="java.lang.String"/>
