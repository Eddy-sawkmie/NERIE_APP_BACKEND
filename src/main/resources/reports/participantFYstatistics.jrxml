	<subDataset name="participantslist" uuid="6f0e2920-7da2-4a76-a595-a3af0c658fa4">
		<parameter name="pphaseid" class="java.lang.String"/>
		<queryString>
			<![CDATA[select distinct(a.usercode), a.applicationcode, a.phaseid, u.username
FROM nerie.t_applications a, nerie.mt_userlogin u, nerie.mt_programdetails pd
where a.phaseid=$P{pphaseid} and a.status='A' and u.usercode=a.usercode and a.phaseid=pd.phaseid]]>
		</queryString>
		<field name="usercode" class="java.lang.String"/>
		<field name="applicationcode" class="java.lang.String"/>
		<field name="phaseid" class="java.lang.String"/>
		<field name="username" class="java.lang.String"/>
	</subDataset>
	<subDataset name="coordinator" uuid="941adaf0-dd7f-4368-869d-7b8c8463b44e">
		<parameter name="ccphaseid" class="java.lang.String"/>
		<queryString>
			<![CDATA[SELECT
    x.usercode,
    x.username,
    x.designationname,
    x.officeshortname
FROM (
    SELECT DISTINCT
        UL.usercode,
        UL.username,
        D.designationname,
        O.officeshortname,
        CC.isheadcoordinator
    FROM nerie.mt_program_members CC
    INNER JOIN nerie.mt_programdetails C ON C.phaseid = CC.phaseid
    INNER JOIN nerie.mt_userlogin UL ON CC.usercode = UL.usercode
    INNER JOIN nerie.m_designations D ON D.designationcode = UL.designationcode
    INNER JOIN nerie.m_offices O ON O.officecode = UL.officecode
    INNER JOIN nerie.m_phases ph ON C.phaseid = ph.phaseid
    WHERE C.phaseid = $P{ccphaseid}
) x
ORDER BY
    CASE
        WHEN x.isheadcoordinator = '1' THEN 0
        ELSE 1
    END,
    x.username;]]>
		</queryString>
		<field name="usercode" class="java.lang.String"/>
		<field name="username" class="java.lang.String"/>
		<field name="designationname" class="java.lang.String"/>
		<field name="officeshortname" class="java.lang.String"/>
		<group name="usercode">
			<groupExpression><![CDATA[$F{usercode}]]></groupExpression>
		</group>
		<group name="username">
			<groupExpression><![CDATA[$F{username}]]></groupExpression>
		</group>
	</subDataset>
	<parameter name="phaseid" class="java.lang.String"/>
	<parameter name="dynamicpath" class="java.lang.String"/>
	<parameter name="participantstatus" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="fystart" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="fyend" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT
    /* Total unique applicants */
    COUNT(DISTINCT a.usercode) AS total_applicants,

    /* Unique attended participants */
    COUNT(DISTINCT CASE WHEN a.status = 'A' THEN a.usercode END)
        AS attended_participants,

    /* Unique pending participants */
    COUNT(DISTINCT CASE WHEN a.status IN ('P','T') THEN a.usercode END)
        AS pending_participants,

    /* Unique rejected participants */
    COUNT(DISTINCT CASE WHEN a.status = 'R' THEN a.usercode END)
        AS rejected_participants,

    /* Programs conducted */
    COUNT(DISTINCT CASE WHEN a.status = 'A' THEN a.phaseid END)
        AS programs_conducted,

    /* Acceptance rate (%) */
    ROUND(
        COUNT(DISTINCT CASE WHEN a.status = 'A' THEN a.usercode END)
        * 100.0
        /
        NULLIF(COUNT(DISTINCT a.usercode), 0),
    2) AS acceptance_rate

FROM nerie.t_applications a

WHERE a.entrydate >= to_date($P{fystart}, 'YYYY-MM')
  AND a.entrydate <  (to_date($P{fyend}, 'YYYY-MM') + INTERVAL '1 month');
]]>
	</queryString>
	<field name="total_applicants" class="java.lang.Long"/>
	<field name="attended_participants" class="java.lang.Long"/>
	<field name="pending_participants" class="java.lang.Long"/>
	<field name="rejected_participants" class="java.lang.Long"/>
	<field name="programs_conducted" class="java.lang.Long"/>
	<field name="acceptance_rate" class="java.math.BigDecimal"/>
